# Canvas
CANVAS_BASE_URL=https://oc.sjtu.edu.cn
CANVAS_TOKEN=your_canvas_access_token_here

# LLM (OpenAI-compatible API)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your_api_key_here
LLM_MODEL=deepseek-chat

# ASR (Whisper 模型：base / small / medium / large-v3)
ASR_MODEL=base
ASR_DEVICE=cuda

# 课堂录屏（从浏览器 F12 → Application → Cookies 复制）
JA_AUTH_COOKIE=your_ja_auth_cookie_here
